# UYTDownloader Configuration

# Ports
UYT_PORT=8000
UYT_FRONTEND_PORT=3000

# Concurrency: safe (1 job), balanced (3), power (6)
UYT_CONCURRENCY_MODE=balanced

# SponsorBlock default: keep, mark_chapters, remove
UYT_SPONSORBLOCK_DEFAULT=keep

# File ownership (match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# Storage management
# Retention: 1_day, 1_week, 1_month, 3_months, 6_months, 1_year, forever
UYT_RETENTION=forever
# Disk guard: auto-delete when free space drops below this percentage
UYT_DISK_GUARD_PCT=10
# Cleanup strategy: oldest_first, newest_first, largest_first, smallest_first
UYT_DISK_GUARD_STRATEGY=oldest_first

# GPU (uncomment for NVIDIA)
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
